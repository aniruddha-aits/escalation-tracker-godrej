# ── Email credentials ─────────────────────────────────────────
EMAIL_ADDRESS=you@gmail.com
EMAIL_PASSWORD=your_app_password
MAILBOX=INBOX
POLL_INTERVAL=30          # seconds (fallback if IDLE not supported)

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Flask ─────────────────────────────────────────────────────
FLASK_SECRET_KEY=change_this_to_a_random_string
FLASK_PORT=5000

# ── Custom IMAP (company/unknown domains only) ────────────────
# CUSTOM_IMAP_HOST=mail.mycompany.com
# CUSTOM_IMAP_PORT=993
